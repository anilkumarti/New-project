# Client does not store the Gemini API key directly.
# Start the proxy server and set GEMINI_API_KEY there.
# Example (server): GEMINI_API_KEY=your_gemini_api_key_here

# Optionally set a custom proxy URL if your server is hosted separately:
# VITE_GEMINI_PROXY_URL=http://localhost:5174
# GEMINI_API_KEY should be stored in fat-kill/server/.env, not in the client root .env.
# GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_PROXY_URL=http://localhost:5174